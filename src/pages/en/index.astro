---
import LayoutEN from '../../layouts/LayoutEN.astro';
const base = import.meta.env.BASE_URL;
---

<LayoutEN title="Private Tennis Lesson in Sapporo">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src={`${base}images/hero/court.jpg`} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/80 via-primary-dark/60 to-primary-dark/90"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 py-32 w-full">
      <div class="max-w-3xl">
        <p class="text-accent font-bold tracking-[0.3em] text-sm mb-6">TENNIS COACHING IN SAPPORO</p>
        <h1 class="text-4xl md:text-7xl font-black text-white mb-8 leading-[1.1] tracking-tight">
          Private Tennis<br />Lesson in Sapporo
        </h1>
        <div class="w-16 h-0.5 bg-accent mb-8"></div>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-12 max-w-lg">
          Learn from a Japanese YouTube coach<br />
          with 7,000+ subscribers
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="border border-accent text-accent hover:bg-accent hover:text-primary-dark font-bold px-10 py-4 transition text-center tracking-wider">
            Book a Lesson
          </a>
          <a href="#lesson-menu" class="border border-white/40 text-white hover:bg-white/10 font-bold px-10 py-4 transition text-center tracking-wider">
            View Pricing
          </a>
        </div>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/50">
      <span class="text-xs tracking-[0.2em]">SCROLL</span>
      <div class="w-px h-10 bg-white/30 animate-pulse"></div>
    </div>
  </section>

  <!-- ===== ABOUT COACH ===== -->
  <section class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark to-primary"></div>
    <p class="absolute top-8 left-4 md:left-12 text-[5rem] md:text-[10rem] font-black text-white/[0.03] leading-none tracking-tight">COACH</p>
    <div class="relative max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] overflow-hidden">
          <img src={`${base}images/features/decoturf-court.jpg`} alt="Coach Kota on court" class="w-full h-full object-cover" />
        </div>
        <div class="text-white">
          <p class="text-accent font-bold tracking-[0.2em] text-sm mb-4">ABOUT</p>
          <h2 class="text-3xl md:text-4xl font-black mb-8 leading-tight">
            Meet Coach Kota
          </h2>
          <div class="w-12 h-0.5 bg-accent mb-8"></div>
          <ul class="text-white/70 leading-loose mb-8 space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1">&#9670;</span>
              <span>Competed in national tournaments since junior years</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1">&#9670;</span>
              <span>Nihon University Tennis Team graduate</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1">&#9670;</span>
              <span>YouTube channel with 7,210+ subscribers</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1">&#9670;</span>
              <span>Specializes in doubles strategy</span>
            </li>
          </ul>
          <a href="https://www.youtube.com/channel/UCKtgQuL9B0c8y42hHnx8JQQ" target="_blank" rel="noopener" class="border border-accent text-accent hover:bg-accent hover:text-primary-dark font-bold px-8 py-3 transition text-center tracking-wider text-sm inline-block">
            Watch on YouTube
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== LESSON MENU ===== -->
  <section id="lesson-menu" class="py-32 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-20">
        <p class="text-[5rem] md:text-[7rem] font-black text-primary/5 leading-none -mb-6 md:-mb-8">PRICE</p>
        <h2 class="text-3xl font-bold relative">Lesson Menu</h2>
      </div>

      <div class="bg-white rounded-2xl shadow-sm overflow-hidden mb-8 border border-gray-100">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-primary text-white">
              <tr>
                <th class="px-6 py-4 text-left">Duration</th>
                <th class="px-6 py-4 text-right">Price</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white hover:bg-accent/5 transition">
                <td class="px-6 py-4">60 minutes</td>
                <td class="px-6 py-4 text-right font-bold text-lg">&yen;8,000 <span class="text-sm font-normal text-text-light">+ court rental</span></td>
              </tr>
              <tr class="bg-bg hover:bg-accent/5 transition">
                <td class="px-6 py-4">90 minutes</td>
                <td class="px-6 py-4 text-right font-bold text-lg">&yen;10,500 <span class="text-sm font-normal text-text-light">+ court rental</span></td>
              </tr>
              <tr class="bg-white hover:bg-accent/5 transition">
                <td class="px-6 py-4">2 hours</td>
                <td class="px-6 py-4 text-right font-bold text-lg">&yen;13,000 <span class="text-sm font-normal text-text-light">+ court rental</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-bg rounded-2xl p-8">
          <h3 class="font-bold text-lg mb-4">Court Rental</h3>
          <p class="text-text-light leading-relaxed">
            &yen;4,400 &ndash; &yen;6,600 / hour<br />
            <span class="text-sm">(varies by season)</span>
          </p>
        </div>
        <div class="bg-bg rounded-2xl p-8">
          <h3 class="font-bold text-lg mb-4">Equipment</h3>
          <p class="text-text-light leading-relaxed">
            Racket &amp; ball rental: <strong class="text-primary">FREE</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHAT'S INCLUDED ===== -->
  <section class="py-32 bg-bg-dark">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-20">
        <p class="text-[5rem] md:text-[7rem] font-black text-primary/5 leading-none -mb-6 md:-mb-8">FEATURES</p>
        <h2 class="text-3xl font-bold relative">What's Included</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm text-center">
          <div class="text-4xl mb-4">&#127934;</div>
          <h3 class="font-bold mb-3">Personalized Coaching</h3>
          <p class="text-text-light text-sm leading-relaxed">Tailored lessons for all levels, from beginners to advanced players.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm text-center">
          <div class="text-4xl mb-4">&#127969;</div>
          <h3 class="font-bold mb-3">Indoor Court</h3>
          <p class="text-text-light text-sm leading-relaxed">Play rain or shine, even in winter! DecoTurf surface.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm text-center">
          <div class="text-4xl mb-4">&#127909;</div>
          <h3 class="font-bold mb-3">Video Feedback</h3>
          <p class="text-text-light text-sm leading-relaxed">Review your form with video recording of your lesson.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm text-center">
          <div class="text-4xl mb-4">&#128647;</div>
          <h3 class="font-bold mb-3">Easy Access</h3>
          <p class="text-text-light text-sm leading-relaxed">10 min from downtown Sapporo by subway.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== LOCATION ===== -->
  <section class="py-32 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-20">
        <p class="text-[5rem] md:text-[7rem] font-black text-primary/5 leading-none -mb-6 md:-mb-8">ACCESS</p>
        <h2 class="text-3xl font-bold relative">Location</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h3 class="text-xl font-bold mb-6">PLACE OF SPORTS NEO</h3>
          <p class="text-text-light leading-loose mb-6">
            Shiroishi Ward, Sapporo
          </p>
          <div class="space-y-4 text-text-light">
            <div class="flex items-start gap-3">
              <span class="text-primary font-bold mt-0.5">&#9679;</span>
              <span>Tozai Subway Line &rarr; <strong class="text-text">Shiroishi Station</strong> &rarr; short walk</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-primary font-bold mt-0.5">&#9679;</span>
              <span>About 10 minutes from downtown Sapporo</span>
            </div>
          </div>
          <div class="mt-8">
            <a href="https://neo-spo.com/" target="_blank" rel="noopener" class="text-primary font-bold border-b border-primary pb-1 hover:opacity-70 transition inline-flex items-center gap-2">
              Visit venue website <span class="text-lg">&rarr;</span>
            </a>
          </div>
        </div>
        <div class="aspect-[4/3] overflow-hidden">
          <img src={`${base}images/en/sapporo_winter.jpg`} alt="Sapporo city in winter" class="w-full h-full object-cover rounded-lg" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== YOUTUBE ===== -->
  <section class="py-32 bg-bg-dark">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-16">
        <p class="text-[5rem] md:text-[7rem] font-black text-primary/5 leading-none -mb-6 md:-mb-8">MOVIE</p>
        <h2 class="text-3xl font-bold relative mb-4">Watch Our Doubles Strategy Videos</h2>
        <p class="text-text-light">Daily tennis tips on our YouTube channel</p>
      </div>
      <div class="aspect-video overflow-hidden shadow-2xl">
        <iframe
          class="w-full h-full"
          src="https://www.youtube.com/embed/bXEScAkbFYI"
          title="Tennis coaching video"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
      <div class="text-center mt-10">
        <a href="https://www.youtube.com/channel/UCKtgQuL9B0c8y42hHnx8JQQ" target="_blank" rel="noopener" class="text-primary font-bold border-b border-primary pb-1 hover:opacity-70 transition inline-flex items-center gap-2">
          Visit our YouTube channel <span class="text-lg">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CTA / BOOK NOW ===== -->
  <section class="relative py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img src={`${base}images/hero/court.jpg`} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-primary-dark/90"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center text-white">
      <p class="text-accent font-bold tracking-[0.2em] text-sm mb-6">BOOK NOW</p>
      <h2 class="text-3xl md:text-4xl font-black mb-6">Ready to Play?</h2>
      <div class="w-12 h-0.5 bg-accent mx-auto mb-8"></div>
      <p class="text-white/70 mb-12 text-lg leading-relaxed">
        Send us a message on LINE to book your lesson!<br />
        We'll reply in English.
      </p>
      <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="border border-accent text-accent hover:bg-accent hover:text-primary-dark font-bold px-12 py-5 transition inline-block text-lg tracking-wider">
        Book via LINE
      </a>
    </div>
  </section>

</LayoutEN>
