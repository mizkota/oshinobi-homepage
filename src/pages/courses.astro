---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const courses = [
  { day: '月曜', time1: '19:30〜21:00', level1: 'CD', time2: '21:10〜22:40', level2: 'B' },
  { day: '火曜', time1: '19:30〜21:00', level1: 'B', time2: '21:10〜22:40', level2: 'BC' },
  { day: '水曜', time1: '19:30〜21:00', level1: '強化/B', time2: '21:10〜22:40', level2: 'CD' },
  { day: '木曜', time1: '19:30〜21:00', level1: 'CD', time2: '21:10〜22:40', level2: 'BC' },
  { day: '金曜', time1: '19:30〜21:00', level1: 'BC', time2: '21:10〜22:40', level2: 'B' },
];
---

<Layout title="コース・料金システム">
  <!-- Hero -->
  <section class="relative py-20">
    <div class="absolute inset-0">
      <img src={`${base}images/hero/court.jpg`} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/90 to-primary/80"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 text-center text-white">
      <h1 class="text-4xl font-bold mb-4">コース・料金システム</h1>
      <p class="text-white/80 text-lg">入会金無料（2024年11月〜）</p>
    </div>
  </section>

  <!-- Flyer Image -->
  <section class="py-16 bg-bg">
    <div class="max-w-2xl mx-auto px-4">
      <img src={`${base}images/courses/flyer.jpg`} alt="コース案内チラシ" class="w-full rounded-2xl shadow-lg" />
    </div>
  </section>

  <!-- Group Lessons -->
  <section class="py-20 bg-bg-dark">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8 text-center">グループレッスン</h2>

      <!-- 定員説明 -->
      <div class="bg-white rounded-2xl p-6 shadow-sm mb-8">
        <h3 class="font-bold text-lg mb-3">定員について</h3>
        <div class="text-text-light space-y-2 text-sm leading-relaxed">
          <p>各コースの<strong class="text-text">レギュラー会員の定員は6名</strong>です。</p>
          <p>振替受講用に1枠を確保しているため、<strong class="text-text">1レッスンの最大参加人数は7名</strong>になる場合があります。</p>
          <p>少人数制を維持するため、7名を超えることはありません。</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm overflow-hidden mb-8">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-primary text-white">
              <tr>
                <th class="px-6 py-4 text-left">曜日</th>
                <th class="px-6 py-4 text-left">前半（19:30〜21:00）</th>
                <th class="px-6 py-4 text-left">後半（21:10〜22:40）</th>
              </tr>
            </thead>
            <tbody>
              {courses.map((c, i) => (
                <tr class={`${i % 2 === 0 ? 'bg-white' : 'bg-bg'} hover:bg-accent/5 transition`}>
                  <td class="px-6 py-4 font-bold">{c.day}</td>
                  <td class="px-6 py-4">{c.level1}クラス</td>
                  <td class="px-6 py-4">{c.level2}クラス</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="bg-accent/10 border border-accent/30 rounded-2xl p-8 mb-8 text-center">
        <p class="text-xl font-bold text-primary mb-2">現在、全コース満員御礼です</p>
        <p class="text-text-light">空き状況はLINEでお問い合わせください</p>
      </div>

      <!-- Pricing -->
      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <h3 class="font-bold text-lg mb-6 text-center">月会費</h3>
          <div class="space-y-4">
            <div class="flex justify-between items-baseline border-b border-gray-100 pb-3">
              <span class="text-text-light">通常期（5月〜10月）</span>
              <span class="text-2xl font-bold text-primary">12,000<span class="text-sm font-normal text-text-light">円/月</span></span>
            </div>
            <div class="flex justify-between items-baseline">
              <span class="text-text-light">冬期（11月〜4月）</span>
              <span class="text-2xl font-bold text-primary">13,000<span class="text-sm font-normal text-text-light">円/月</span></span>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <h3 class="font-bold text-lg mb-6 text-center">単発受講</h3>
          <div class="space-y-4">
            <div class="flex justify-between items-baseline border-b border-gray-100 pb-3">
              <span class="text-text-light">通常期</span>
              <span class="text-2xl font-bold text-primary">3,500<span class="text-sm font-normal text-text-light">円/回</span></span>
            </div>
            <div class="flex justify-between items-baseline">
              <span class="text-text-light">冬期</span>
              <span class="text-2xl font-bold text-primary">3,800<span class="text-sm font-normal text-text-light">円/回</span></span>
            </div>
          </div>
        </div>
      </div>

      <p class="text-sm text-text-light text-center">
        レギュラー定員：各コース6名（+振替枠1名） ／ 会場：PLACE OF SPORTS NEO（デコターフコート）
      </p>
    </div>
  </section>

  <!-- Private Lessons -->
  <section class="py-20 bg-bg">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8 text-center">プライベートレッスン</h2>

      <div class="bg-white rounded-2xl shadow-sm overflow-hidden mb-8">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-primary text-white">
              <tr>
                <th class="px-6 py-4 text-left">時間</th>
                <th class="px-6 py-4 text-right">料金</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white hover:bg-accent/5 transition"><td class="px-6 py-4">1時間</td><td class="px-6 py-4 text-right font-bold text-lg">7,000円</td></tr>
              <tr class="bg-bg hover:bg-accent/5 transition"><td class="px-6 py-4">1.5時間</td><td class="px-6 py-4 text-right font-bold text-lg">9,000円</td></tr>
              <tr class="bg-white hover:bg-accent/5 transition"><td class="px-6 py-4">2時間</td><td class="px-6 py-4 text-right font-bold text-lg">11,000円</td></tr>
              <tr class="bg-bg hover:bg-accent/5 transition"><td class="px-6 py-4">2.5時間</td><td class="px-6 py-4 text-right font-bold text-lg">13,000円</td></tr>
              <tr class="bg-white hover:bg-accent/5 transition"><td class="px-6 py-4">3時間</td><td class="px-6 py-4 text-right font-bold text-lg">15,000円</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-sm">
        <h3 class="font-bold text-lg mb-4">プライベートレッスンについて</h3>
        <ul class="text-text-light space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold">●</span>
            <span>最大6名まで参加可能</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold">●</span>
            <span>会員でなくても受講可能</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold">●</span>
            <span>コートはお客様にてご手配ください</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold">●</span>
            <span>白石区・中央区在住の方は無料で出張いたします</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <h2 class="text-2xl font-bold mb-6">お問い合わせ・体験レッスンのお申し込み</h2>
    <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="bg-accent hover:bg-accent-light text-primary-dark font-bold px-10 py-4 rounded-lg transition inline-block text-lg shadow-lg">
      LINE でお問い合わせ
    </a>
  </section>
</Layout>
