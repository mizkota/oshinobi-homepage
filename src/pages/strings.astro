---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const strings = [
  {
    name: 'ツイスター',
    brand: 'Signum Pro',
    material: 'ポリエステル',
    gauge: '1.20mm',
    price: 2800,
    image: 'twister.webp',
    description: 'スピン性能に優れたコストパフォーマンス抜群のポリストリング。回転系プレーヤーにおすすめ。',
  },
  {
    name: 'トルネード',
    brand: 'Signum Pro',
    material: 'ポリエステル',
    gauge: '1.23mm',
    price: 2800,
    image: 'tornado.webp',
    description: '独特の螺旋形状でスピンとコントロールを両立。パワーとスピンのバランスが取れた一本。',
  },
  {
    name: 'ポリツアープロ',
    brand: 'YONEX',
    material: 'ポリエステル',
    gauge: '1.25mm',
    price: 3000,
    image: 'polytour-pro.webp',
    description: 'YONEXの定番ポリストリング。ソフトな打球感とスピン性能を兼ね備えた万能型。',
  },
  {
    name: 'HYPER-G',
    brand: 'Solinco',
    material: 'ポリエステル',
    gauge: '1.25mm',
    price: 3000,
    image: 'hyper-g.webp',
    description: '五角形断面によるスピン特化型。ヘビースピンを求めるプレーヤーに人気。',
  },
  {
    name: 'RPMブラスト',
    brand: 'Babolat',
    material: 'ポリエステル',
    gauge: '1.25/1.30mm',
    price: 3000,
    image: 'rpm-blast.webp',
    description: 'ナダル使用で有名なBabolatの看板ストリング。高いスピン性能とコントロール性。',
  },
  {
    name: 'マッハ-10',
    brand: 'Solinco',
    material: 'ポリエステル',
    gauge: '1.25mm',
    price: 3100,
    image: 'mach10.jpg',
    description: 'パワーとスピンを高次元で融合。爆発的なボールスピードを生み出す攻撃型ストリング。',
  },
  {
    name: 'ポリツアーレブ',
    brand: 'YONEX',
    material: 'ポリエステル',
    gauge: '1.25mm',
    price: 3200,
    image: 'polytour-rev.webp',
    description: 'ポリツアープロの上位モデル。より高い反発力でパワーショットを可能に。',
  },
  {
    name: 'アルパワー',
    brand: 'Luxilon',
    material: 'ポリエステル',
    gauge: '1.25mm',
    price: 3200,
    image: 'alu-power.webp',
    description: 'フェデラーも使用した世界的名作。パワー・コントロール・フィーリングの全てが高水準。',
  },
  {
    name: 'X-ONE バイフェイズ',
    brand: 'Tecnifibre',
    material: 'ナイロン',
    gauge: '1.24mm',
    price: 3600,
    image: 'xone-biphase.webp',
    description: 'ナイロン最高峰の打球感。ナチュラルガットに近い柔らかさとホールド感を実現。',
  },
];
---

<Layout title="指定ガット・料金一覧表">
  <section class="relative py-20">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark to-primary"></div>
    <div class="relative max-w-6xl mx-auto px-4 text-center text-white">
      <h1 class="text-4xl font-bold mb-4">指定ガット・料金一覧</h1>
      <p class="text-white/80 text-lg">全品工賃込み・追加料金なし</p>
    </div>
  </section>

  <section class="py-20 bg-bg">
    <div class="max-w-5xl mx-auto px-4">
      <div class="space-y-6">
        {strings.map((s) => (
          <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition overflow-hidden">
            <div class="flex flex-col sm:flex-row">
              <div class="sm:w-40 h-40 sm:h-auto bg-gray-50 flex items-center justify-center p-4 shrink-0">
                <img src={`${base}images/strings/${s.image}`} alt={s.name} class="max-h-32 max-w-full object-contain" />
              </div>
              <div class="flex-1 p-6">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-3">
                  <div>
                    <h2 class="text-xl font-bold">{s.name}</h2>
                    <p class="text-text-light text-sm">{s.brand} / {s.material} / {s.gauge}</p>
                  </div>
                  <div class="text-2xl font-bold text-primary whitespace-nowrap">
                    {s.price.toLocaleString()}<span class="text-sm font-normal text-text-light">円</span>
                  </div>
                </div>
                <p class="text-text-light text-sm leading-relaxed">{s.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-primary text-white text-center">
    <h2 class="text-2xl font-bold mb-6">ご注文はLINEから</h2>
    <a href="https://lin.ee/IY3lcQP" target="_blank" rel="noopener" class="bg-accent hover:bg-accent-light text-primary-dark font-bold px-10 py-4 rounded-lg transition inline-block text-lg shadow-lg">
      LINE で注文する
    </a>
  </section>
</Layout>
