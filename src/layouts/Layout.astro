---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '札幌のテニススクール「御忍庭球塾」。少人数制レッスンで、もっと充実したテニスライフを。' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <title>{title} | 御忍庭球塾</title>
    <link rel="alternate" hreflang="ja" href="https://oshinobitennis.com/" />
    <link rel="alternate" hreflang="en" href="https://oshinobitennis.com/en" />
    <slot name="head" />
  </head>
  <body class="bg-white text-text font-sans">
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={base} class="flex items-center gap-3 hover:opacity-70 transition">
          <img src={`${base}images/logo/logo.png`} alt="御忍庭球塾" class="h-8" />
        </a>
        <div class="flex items-center gap-4">
          <a href={`${base}en`} class="text-sm text-text-light hover:text-primary transition font-medium">
            English
          </a>
          <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="hidden md:flex items-center gap-2 border border-primary text-primary hover:bg-primary hover:text-white px-6 py-2 text-sm font-bold transition tracking-wider">
            お問い合わせ・体験の申し込み
          </a>
          <button id="menu-toggle" class="p-2 flex flex-col gap-1.5" aria-label="メニュー">
            <span class="block w-6 h-0.5 bg-text transition" id="menu-bar-1"></span>
            <span class="block w-6 h-0.5 bg-text transition" id="menu-bar-2"></span>
            <span class="block w-4 h-0.5 bg-text transition ml-auto" id="menu-bar-3"></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Fullscreen Menu Overlay -->
    <div id="menu-overlay" class="fixed inset-0 z-40 bg-primary-dark/95 backdrop-blur-md hidden opacity-0 transition-opacity duration-500">
      <div class="flex items-center justify-center h-full">
        <nav class="text-center">
          <div class="space-y-8">
            <a href={`${base}courses`} class="block text-white text-2xl font-bold tracking-wider hover:text-accent transition">コース・料金</a>
            <a href={`${base}gut24`} class="block text-white text-2xl font-bold tracking-wider hover:text-accent transition">ガット張替</a>
            <a href={`${base}terms`} class="block text-white text-2xl font-bold tracking-wider hover:text-accent transition">利用規約</a>
            <a href={`${base}blog`} class="block text-white text-2xl font-bold tracking-wider hover:text-accent transition">お知らせ</a>
            <a href={`${base}en`} class="block text-white text-2xl font-bold tracking-wider hover:text-accent transition">English</a>
          </div>
          <div class="mt-12 pt-8 border-t border-white/20">
            <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="border border-accent text-accent hover:bg-accent hover:text-primary-dark font-bold px-10 py-4 transition inline-block tracking-wider">
              体験のお申し込み
            </a>
          </div>
        </nav>
      </div>
    </div>

    <!-- Spacer for fixed header -->
    <div class="h-16"></div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-primary-dark text-white">
      <div class="max-w-7xl mx-auto px-6 py-20">
        <div class="grid md:grid-cols-3 gap-16">
          <div>
            <img src={`${base}images/logo/logo.png`} alt="御忍庭球塾" class="h-10 mb-6 brightness-0 invert" />
            <p class="text-sm text-white/50 leading-relaxed">
              札幌市白石区を拠点に活動するテニススクール。<br />
              少人数制で一人ひとりに寄り添ったレッスンを提供しています。
            </p>
          </div>
          <div>
            <h3 class="text-sm font-bold tracking-wider text-accent mb-6">LINE</h3>
            <div class="space-y-4 text-sm">
              <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="flex items-center gap-2 text-white/70 hover:text-accent transition">
                <span>→</span> レッスンのお問い合わせ
              </a>
              <a href="https://lin.ee/5MOenxx" target="_blank" rel="noopener" class="flex items-center gap-2 text-white/70 hover:text-accent transition">
                <span>→</span> ガット張替のお問い合わせ
              </a>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-bold tracking-wider text-accent mb-6">LINKS</h3>
            <div class="space-y-4 text-sm">
              <a href="https://www.youtube.com/channel/UCKtgQuL9B0c8y42hHnx8JQQ" target="_blank" rel="noopener" class="flex items-center gap-2 text-white/70 hover:text-accent transition">
                <span>→</span> YouTube チャンネル
              </a>
              <a href="https://neo-spo.com/" target="_blank" rel="noopener" class="flex items-center gap-2 text-white/70 hover:text-accent transition">
                <span>→</span> PLACE OF SPORTS NEO
              </a>
            </div>
          </div>
        </div>
        <div class="border-t border-white/10 mt-16 pt-8 text-center text-xs text-white/30 tracking-wider">
          <p>&copy; {new Date().getFullYear()} 御忍庭球塾 All Rights Reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const overlay = document.getElementById('menu-overlay');
      const bar1 = document.getElementById('menu-bar-1');
      const bar2 = document.getElementById('menu-bar-2');
      const bar3 = document.getElementById('menu-bar-3');
      let isOpen = false;

      toggle?.addEventListener('click', () => {
        isOpen = !isOpen;
        if (isOpen) {
          overlay?.classList.remove('hidden');
          requestAnimationFrame(() => {
            overlay?.classList.remove('opacity-0');
            overlay?.classList.add('opacity-100');
          });
          bar1?.classList.add('rotate-45', 'translate-y-[4px]');
          bar2?.classList.add('opacity-0');
          bar3?.classList.add('-rotate-45', '-translate-y-[4px]', 'w-6', 'ml-0');
          document.body.style.overflow = 'hidden';
        } else {
          overlay?.classList.remove('opacity-100');
          overlay?.classList.add('opacity-0');
          setTimeout(() => overlay?.classList.add('hidden'), 500);
          bar1?.classList.remove('rotate-45', 'translate-y-[4px]');
          bar2?.classList.remove('opacity-0');
          bar3?.classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6', 'ml-0');
          document.body.style.overflow = '';
        }
      });

      // Close on link click
      overlay?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          toggle?.click();
        });
      });
    </script>
  </body>
</html>
