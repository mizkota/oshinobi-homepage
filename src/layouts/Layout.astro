---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '札幌のテニススクール「御忍庭球塾」。少人数制レッスンで、もっと充実したテニスライフを。' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <title>{title} | 御忍庭球塾</title>
  </head>
  <body class="bg-bg text-text font-sans">
    <header class="bg-primary-dark text-white sticky top-0 z-50 shadow-lg">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href={base} class="text-xl font-bold tracking-wide hover:opacity-80 transition">
          御忍庭球塾
        </a>
        <button id="menu-toggle" class="md:hidden p-2" aria-label="メニュー">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <nav id="nav-menu" class="hidden md:flex gap-6 text-sm font-medium">
          <a href={`${base}features`} class="hover:text-accent-light transition">特徴</a>
          <a href={`${base}courses`} class="hover:text-accent-light transition">コース・料金</a>
          <a href={`${base}gut24`} class="hover:text-accent-light transition">ガット張替</a>
          <a href={`${base}strings`} class="hover:text-accent-light transition">ガット一覧</a>
          <a href={`${base}terms`} class="hover:text-accent-light transition">利用規約</a>
          <a href={`${base}blog`} class="hover:text-accent-light transition">お知らせ</a>
        </nav>
      </div>
      <nav id="mobile-menu" class="hidden md:hidden bg-primary-dark border-t border-primary px-4 pb-4">
        <div class="flex flex-col gap-3 text-sm font-medium pt-2">
          <a href={`${base}features`} class="hover:text-accent-light transition py-1">特徴</a>
          <a href={`${base}courses`} class="hover:text-accent-light transition py-1">コース・料金</a>
          <a href={`${base}gut24`} class="hover:text-accent-light transition py-1">ガット張替</a>
          <a href={`${base}strings`} class="hover:text-accent-light transition py-1">ガット一覧</a>
          <a href={`${base}terms`} class="hover:text-accent-light transition py-1">利用規約</a>
          <a href={`${base}blog`} class="hover:text-accent-light transition py-1">お知らせ</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-primary-dark text-white">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <h3 class="font-bold text-lg mb-4">御忍庭球塾</h3>
            <p class="text-sm text-white/70 leading-relaxed">
              札幌市白石区を拠点に活動するテニススクール。<br />
              少人数制で一人ひとりに寄り添ったレッスンを提供しています。
            </p>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-4">LINE でお問い合わせ</h3>
            <div class="space-y-3 text-sm">
              <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="block hover:text-accent-light transition">
                ▶ レッスンのお問い合わせ
              </a>
              <a href="https://lin.ee/Cc2Tbvk" target="_blank" rel="noopener" class="block hover:text-accent-light transition">
                ▶ ガット張替のお問い合わせ
              </a>
            </div>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-4">リンク</h3>
            <div class="space-y-3 text-sm">
              <a href="https://www.youtube.com/channel/UCKtgQuL9B0c8y42hHnx8JQQ" target="_blank" rel="noopener" class="block hover:text-accent-light transition">
                ▶ YouTube チャンネル
              </a>
              <a href="https://neo-spo.com/" target="_blank" rel="noopener" class="block hover:text-accent-light transition">
                ▶ PLACE OF SPORTS NEO
              </a>
            </div>
          </div>
        </div>
        <div class="border-t border-white/20 mt-8 pt-6 text-center text-sm text-white/50">
          <p>&copy; {new Date().getFullYear()} 御忍庭球塾 All Rights Reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
