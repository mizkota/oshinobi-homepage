---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Private tennis lessons in Sapporo, Japan. Learn from a YouTube coach with 7,000+ subscribers.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <title>{title} | Oshinobi Tennis</title>
    <link rel="alternate" hreflang="ja" href="https://oshinobitennis.com/" />
    <link rel="alternate" hreflang="en" href="https://oshinobitennis.com/en" />
    <slot name="head" />
  </head>
  <body class="bg-white text-text font-sans">
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={`${base}en`} class="flex items-center gap-3 hover:opacity-70 transition">
          <img src={`${base}images/logo/logo.png`} alt="Oshinobi Tennis" class="h-8" />
        </a>
        <div class="flex items-center gap-4">
          <a href={base} class="text-sm text-text-light hover:text-primary transition font-medium">
            日本語
          </a>
          <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="hidden md:flex items-center gap-2 border border-primary text-primary hover:bg-primary hover:text-white px-6 py-2 text-sm font-bold transition tracking-wider">
            Book a Lesson
          </a>
          <button id="menu-toggle-en" class="p-2 flex flex-col gap-1.5" aria-label="Menu">
            <span class="block w-6 h-0.5 bg-text transition" id="menu-bar-1-en"></span>
            <span class="block w-6 h-0.5 bg-text transition" id="menu-bar-2-en"></span>
            <span class="block w-4 h-0.5 bg-text transition ml-auto" id="menu-bar-3-en"></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Fullscreen Menu Overlay -->
    <div id="menu-overlay-en" class="fixed inset-0 z-40 bg-primary-dark/95 backdrop-blur-md hidden opacity-0 transition-opacity duration-500">
      <div class="flex items-center justify-center h-full">
        <nav class="text-center">
          <div class="space-y-8">
            <a href={`${base}en`} class="block text-white text-2xl font-bold tracking-wider hover:text-accent transition">Home</a>
            <a href={base} class="block text-white text-2xl font-bold tracking-wider hover:text-accent transition">日本語サイト</a>
          </div>
          <div class="mt-12 pt-8 border-t border-white/20">
            <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="border border-accent text-accent hover:bg-accent hover:text-primary-dark font-bold px-10 py-4 transition inline-block tracking-wider">
              Book a Lesson
            </a>
          </div>
        </nav>
      </div>
    </div>

    <!-- Spacer for fixed header -->
    <div class="h-16"></div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-primary-dark text-white">
      <div class="max-w-7xl mx-auto px-6 py-20">
        <div class="grid md:grid-cols-3 gap-16">
          <div>
            <img src={`${base}images/logo/logo.png`} alt="Oshinobi Tennis" class="h-10 mb-6 brightness-0 invert" />
            <p class="text-sm text-white/50 leading-relaxed">
              Private tennis coaching in Sapporo, Japan.<br />
              Personalized lessons for all levels.
            </p>
          </div>
          <div>
            <h3 class="text-sm font-bold tracking-wider text-accent mb-6">CONTACT</h3>
            <div class="space-y-4 text-sm">
              <a href="https://lin.ee/2CKErIS" target="_blank" rel="noopener" class="flex items-center gap-2 text-white/70 hover:text-accent transition">
                <span>&rarr;</span> Book via LINE
              </a>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-bold tracking-wider text-accent mb-6">LINKS</h3>
            <div class="space-y-4 text-sm">
              <a href="https://www.youtube.com/channel/UCKtgQuL9B0c8y42hHnx8JQQ" target="_blank" rel="noopener" class="flex items-center gap-2 text-white/70 hover:text-accent transition">
                <span>&rarr;</span> YouTube Channel
              </a>
              <a href="https://neo-spo.com/" target="_blank" rel="noopener" class="flex items-center gap-2 text-white/70 hover:text-accent transition">
                <span>&rarr;</span> PLACE OF SPORTS NEO
              </a>
              <a href={base} class="flex items-center gap-2 text-white/70 hover:text-accent transition">
                <span>&rarr;</span> 日本語サイト
              </a>
            </div>
          </div>
        </div>
        <div class="border-t border-white/10 mt-16 pt-8 text-center text-xs text-white/30 tracking-wider">
          <p>&copy; {new Date().getFullYear()} Oshinobi Tennis. All Rights Reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle-en');
      const overlay = document.getElementById('menu-overlay-en');
      const bar1 = document.getElementById('menu-bar-1-en');
      const bar2 = document.getElementById('menu-bar-2-en');
      const bar3 = document.getElementById('menu-bar-3-en');
      let isOpen = false;

      toggle?.addEventListener('click', () => {
        isOpen = !isOpen;
        if (isOpen) {
          overlay?.classList.remove('hidden');
          requestAnimationFrame(() => {
            overlay?.classList.remove('opacity-0');
            overlay?.classList.add('opacity-100');
          });
          bar1?.classList.add('rotate-45', 'translate-y-[4px]');
          bar2?.classList.add('opacity-0');
          bar3?.classList.add('-rotate-45', '-translate-y-[4px]', 'w-6', 'ml-0');
          document.body.style.overflow = 'hidden';
        } else {
          overlay?.classList.remove('opacity-100');
          overlay?.classList.add('opacity-0');
          setTimeout(() => overlay?.classList.add('hidden'), 500);
          bar1?.classList.remove('rotate-45', 'translate-y-[4px]');
          bar2?.classList.remove('opacity-0');
          bar3?.classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6', 'ml-0');
          document.body.style.overflow = '';
        }
      });

      overlay?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          toggle?.click();
        });
      });
    </script>
  </body>
</html>
